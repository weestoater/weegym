# Example Environment Variables for Supabase Config
# Copy this file to .env and fill in your actual values
# DON'T commit the actual .env file!

# ============================================================================
# SOURCE DATABASE (WeeGym Original)
# ============================================================================
# Use these when exporting data from WeeGym
VITE_SUPABASE_URL=https://your-weegym-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# DESTINATION DATABASE (Your CMS)
# ============================================================================
# Use these when importing data to your new CMS
# Uncomment and use when ready to import
# VITE_SUPABASE_URL=https://your-cms-project.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# NEXT.JS PROJECTS
# ============================================================================
# If using Next.js, use these variable names instead:
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# AUTHENTICATION (Optional for Migration)
# ============================================================================
# If your migration script requires authentication:
# USER_EMAIL=your-email@example.com
# USER_PASSWORD=your-password

# ============================================================================
# GETTING YOUR CREDENTIALS
# ============================================================================
# 1. Go to https://supabase.com
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy:
#    - Project URL (VITE_SUPABASE_URL)
#    - anon/public key (VITE_SUPABASE_ANON_KEY)
