# Environment Variables Template
# Copy this to .env and fill in your actual values
# WARNING: Never commit .env files to version control!

# ========================================
# Supabase Configuration
# ========================================
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key (Server-side only - DO NOT expose to client)
# Used by Edge Functions only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ========================================
# Strava API Configuration
# ========================================
# Get credentials from: https://www.strava.com/settings/api
VITE_STRAVA_CLIENT_ID=your-strava-client-id
VITE_STRAVA_CLIENT_SECRET=your-strava-client-secret

# OAuth Redirect URI (must match Strava app settings)
# Development: http://localhost:5173/strava-callback
# Production: https://yourdomain.com/strava-callback
VITE_STRAVA_REDIRECT_URI=http://localhost:5173/strava-callback

# ========================================
# Strava Webhook Configuration
# ========================================
# Random string for webhook verification (generate with: openssl rand -hex 20)
# Must be set in Supabase secrets: supabase secrets set STRAVA_VERIFY_TOKEN=...
STRAVA_VERIFY_TOKEN=your-random-verify-token-here

# ========================================
# Application Configuration
# ========================================
# Base path for routing (used by Vite and React Router)
# Local development: /
# GitHub Pages: /weegym/
# See .env.development for development-specific overrides
VITE_BASE_PATH=/weegym/
